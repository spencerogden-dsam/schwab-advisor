        "type": "object",
        "properties": {
          "id": {
            "description": "The unique identifier of the account holder.\n",
            "type": "number",
            "example": 162669664
          },
          "type": {
            "description": "The type of the object returned.\n",
            "type": "string",
            "example": "account-holder"
          },
          "attributes": {
            "$ref": "#/components/schemas/ProfilesAccountHoldersGetResponseDataAttributes"
          }
        }
      },
      "ProfilesAccountHoldersGetResponseDataAttributes": {
        "type": "object",
        "properties": {
          "role": {
            "description": "The role the account holder plays on the passed account. If the account holder has multiple roles, the highest priority role will be returned.\n",
            "type": "string",
            "example": "Individual"
          },
          "name": {
            "description": "The account holder's name.\n",
            "type": "string",
            "example": "CHRIS M LANG"
          },
          "formattedDateOfBirth": {
            "$ref": "#/components/schemas/FormattedDateOfBirth"
          },
          "formattedTaxpayerId": {
            "$ref": "#/components/schemas/FormattedTaxpayerId"
          },
          "emailAddress": {
            "description": "The account holder's email address.\n",
            "type": "string",
            "example": "test@test.com"
          },
          "homePhone": {
            "description": "The account holder's home phone number.\n",
            "type": "string",
            "example": "415-123-5314"
          },
          "mobilePhone": {
            "description": "The account holder's mobile phone number.\n",
            "type": "string",
            "example": "602-223-2222"
          },
          "businessPhone": {
            "description": "The account holder's business phone number.\n",
            "type": "string",
            "example": "895-541-9876"
          },
          "mailingAddress": {
            "$ref": "#/components/schemas/MailingAddress"
          },
          "citizenship": {
            "description": "The account holder's country of citizenship.\n",
            "type": "string",
            "example": "US"
          },
          "countryOfResidence": {
            "description": "The account holder's country of residence.\n",
            "type": "string",
            "example": "US"
          },
          "allianceWebAccess": {
            "description": "Indicates whether the account holder is enabled for Schwab Alliance.\n",
            "type": "string",
            "enum": [
              "Yes",
              "No",
              "Pending",
              "NotApplicable"
            ]
          },
          "allianceInvitationDate": {
            "description": "The date (EST) when the Alliance Invitation was last sent from SAC.\n",
            "type": "string",
            "format": "date",
            "example": "2022-11-15"
          },
          "mobileAccess": {
            "description": "Indicates if the account holder has logged on to the Schwab mobile app within the past 90 days.\n",
            "type": "string",
            "enum": [
              "Yes",
              "No",
              "Ineligible"
            ]
          },
          "isTrustAccount": {
            "description": "Indicates whether the account is a Trust account.\n",
            "type": "boolean"
          },
          "employment": {
            "$ref": "#/components/schemas/Employment"
          },
          "accounts": {
            "description": "The accounts on which the account holder has a role (i.e., an account on which the account holder has 4 roles will appear 4 times).\n",
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Account"
            }
          }
        }
      },
      "MailingAddress": {
        "type": "object",
        "properties": {
          "address": {
            "description": "The address.\n",
            "type": "string",
            "example": "10822 HARROGATE PLACE Unit 412 West End"
          },
          "city": {
            "description": "The city.\n",
            "type": "string",
            "example": "Denver"
          },
          "stateZip": {
            "description": "The state and ZIP code.\n",
            "type": "string",
            "example": "CO 80022"
          },
          "country": {
            "description": "The country.\n",
            "type": "string",
            "example": "US"
          }
        }
      },
      "Employment": {
        "type": "object",
        "properties": {
          "employmentStatus": {
            "description": "The account holder's employment status.\n",
            "type": "string",
            "example": "Employed"
          },
          "occupation": {
            "description": "The account holder's occupation.\n",
            "type": "string",
            "example": "Engineer"
          },
          "employerName": {
            "description": "The account holder's employer name.\n",
            "type": "string",
            "example": "Charles Schwab"
          },
          "publiclyTradedCompany": {
            "description": "The name of the publicly traded company the account holder is affiliated with or employed by.\n",
            "type": "string",
            "example": "Charles Schwab"
          },
          "isEmployedBySecurityOrBrokerFirm": {
            "description": "Indicates whether the account holder is affiliated with or employed by a stock exchange, member firm or an exchange or FINRA, or a municipal securities broker/dealer.\n",
            "type": "boolean"
          }
        }
      },
      "Account": {
        "type": "object",
        "properties": {
          "formattedAccount": {
            "$ref": "#/components/schemas/FormattedAccount"
          },
          "accountName": {
            "description": "The account name.\n",
            "type": "string",
            "example": "GALE MORGAN BUSH-STONE"
          },
          "role": {
            "description": "The role the account holder plays on the account.\n",
            "type": "string",
            "example": "Individual"
          },
          "accountRegistrationType": {
            "description": "The account registration type.\n",
            "type": "string",
            "example": "Roth Contributory IRA"
          }
        }
      },
      "FormattedAccount": {
        "description": "The unique identifier of the client account.\n",
        "type": "string",
        "example": "*****0120"
      },
      "FormattedDateOfBirth": {
        "description": "The account holder's date of birth.\n",
        "type": "string",
        "example": "****-01-05"
      },
      "FormattedTaxpayerId": {
        "description": "The account holder's Taxpayer ID.\n",
        "type": "string",
        "example": "*****6789"
      },
